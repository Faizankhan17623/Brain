# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Claude sync (claude.ai) ──────────────────────────────────────────────────
# Get this from: claude.ai → F12 → Application → Cookies → sessionKey
CLAUDE_SESSION_KEY=PASTE_YOUR_CLAUDE_SESSION_KEY_HERE

# ── ChatGPT sync (chat.openai.com) ───────────────────────────────────────────
# Get this from: chat.openai.com → F12 → Application → Cookies → __Secure-next-auth.session-token
# Only needed if you use sync_chatgpt.py
CHATGPT_SESSION_TOKEN=PASTE_YOUR_CHATGPT_SESSION_TOKEN_HERE

# ── Vault path (optional override) ───────────────────────────────────────────
# Defaults to the folder containing this .env file
# VAULT_PATH=C:/Users/yourname/path/to/Brain
